## Production Environment Configuration for Vercel
# Backend URL points to Render API Gateway
#
# ============================================
# SINGLE SOURCE OF TRUTH for API Gateway URL
# Change ONLY VITE_API_GATEWAY_URL when the gateway URL changes.
# ============================================
VITE_API_GATEWAY_URL=https://kelmah-api-gateway-qmd7.onrender.com
VITE_API_URL=https://kelmah-api-gateway-qmd7.onrender.com/api
VITE_WS_URL=wss://kelmah-api-gateway-qmd7.onrender.com

# App Configuration
VITE_APP_NAME=Kelmah
VITE_APP_VERSION=1.0.4
VITE_APP_DESCRIPTION=Connect Vocational Workers with Hirers

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_MESSAGING=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_PAYMENTS=true

