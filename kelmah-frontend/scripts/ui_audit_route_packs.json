{
  "defaultPack": "core-public",
  "packs": {
    "core-public": {
      "description": "Primary public routes used as stable UI baseline references.",
      "routes": [
        {
          "id": "home",
          "path": "/",
          "baselineId": "core-public-home"
        },
        {
          "id": "jobs",
          "path": "/jobs",
          "baselineId": "core-public-jobs"
        },
        {
          "id": "search",
          "path": "/search",
          "baselineId": "core-public-search"
        },
        {
          "id": "support",
          "path": "/support",
          "baselineId": "core-public-support"
        },
        {
          "id": "docs",
          "path": "/docs",
          "baselineId": "core-public-docs"
        },
        {
          "id": "community",
          "path": "/community",
          "baselineId": "core-public-community"
        }
      ]
    },
    "hirer-core": {
      "description": "Hirer workflow routes using mock auth stubs for consistent audit runs.",
      "routes": [
        {
          "id": "hirer-dashboard",
          "path": "/hirer/dashboard",
          "baselineId": "hirer-core-dashboard",
          "mockAuth": true
        },
        {
          "id": "hirer-applications",
          "path": "/hirer/applications",
          "baselineId": "hirer-core-applications",
          "mockAuth": true,
          "mockApplications": true
        }
      ]
    },
    "protected-wave3": {
      "description": "Wave 3 protected flows for jobs, applications, and messaging across worker and hirer roles.",
      "routes": [
        {
          "id": "worker-find-work",
          "path": "/worker/find-work",
          "baselineId": "protected-wave3-worker-find-work",
          "mockAuth": true,
          "mockRole": "worker"
        },
        {
          "id": "hirer-jobs",
          "path": "/hirer/jobs",
          "baselineId": "protected-wave3-hirer-jobs",
          "mockAuth": true,
          "mockRole": "hirer"
        },
        {
          "id": "worker-applications",
          "path": "/worker/applications",
          "baselineId": "protected-wave3-worker-applications",
          "mockAuth": true,
          "mockRole": "worker"
        },
        {
          "id": "hirer-applications",
          "path": "/hirer/applications",
          "baselineId": "protected-wave3-hirer-applications",
          "mockAuth": true,
          "mockRole": "hirer",
          "mockApplications": true
        },
        {
          "id": "worker-messages",
          "path": "/messages",
          "baselineId": "protected-wave3-worker-messages",
          "mockAuth": true,
          "mockRole": "worker"
        },
        {
          "id": "hirer-messages",
          "path": "/messages",
          "baselineId": "protected-wave3-hirer-messages",
          "mockAuth": true,
          "mockRole": "hirer"
        }
      ]
    }
  }
}
