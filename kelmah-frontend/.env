# API gateway URL is intentionally not hardcoded here.
# Production values should come from Vercel environment variables.
# Local development can rely on the Vite proxy fallback to localhost:5000,
# or you can uncomment custom values below when needed.
# VITE_API_GATEWAY_URL=http://localhost:5000
# VITE_API_URL=http://localhost:5000/api
# VITE_WS_URL=ws://localhost:5000
