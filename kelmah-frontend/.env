# Render-based backend connection for production deployment
# Backend runs on Render, frontend connects via Render URL
#
# ============================================
# SINGLE SOURCE OF TRUTH for API Gateway URL
# Change ONLY this variable when the gateway URL changes.
# VITE_API_URL and VITE_WS_URL are derived from it.
# ============================================
VITE_API_GATEWAY_URL=https://kelmah-api-gateway-qmd7.onrender.com
VITE_API_URL=https://kelmah-api-gateway-qmd7.onrender.com/api
VITE_WS_URL=wss://kelmah-api-gateway-qmd7.onrender.com
# Set this locally if needed for development, e.g.:
# VITE_API_GATEWAY_URL=http://localhost:5000
# VITE_API_URL=http://localhost:5000/api
# VITE_WS_URL=ws://localhost:5000
