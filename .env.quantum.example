# Quantum provider runtime configuration
# Copy this file to .env.quantum.local and fill in only the providers you use.

# Enable simulation fallback mode (true/false)
QUANTUM_PROVIDER_SIMULATION=false

# Local open-source provider (Qiskit Aer, no cloud account/API key required)
QUANTUM_LOCAL_QISKIT_ENABLED=true
# Use only local Qiskit provider for quantum workloads (true/false)
QUANTUM_LOCAL_QISKIT_ONLY=true
# Optional custom Python command path
QUANTUM_LOCAL_QISKIT_PYTHON=
# Optional adapter timeout in milliseconds
QUANTUM_LOCAL_QISKIT_TIMEOUT_MS=20000

# IBM Quantum (Runtime / adapter)
IBM_QUANTUM_ENDPOINT=
IBM_QUANTUM_API_KEY=
# Optional aliases recognized by runtime:
# QISKIT_RUNTIME_ENDPOINT=
# QISKIT_IBM_TOKEN=

# AWS Braket (adapter endpoint expected by current runtime)
AWS_BRAKET_ENDPOINT=
AWS_BRAKET_API_KEY=

# Azure Quantum
AZURE_QUANTUM_ENDPOINT=
AZURE_QUANTUM_API_KEY=
# Optional alias recognized by runtime:
# AZURE_QUANTUM_KEY=

# D-Wave Leap
DWAVE_ENDPOINT=
DWAVE_API_TOKEN=
# Optional aliases recognized by runtime:
# DWAVE_API_KEY=
# DWAVE_TOKEN=
